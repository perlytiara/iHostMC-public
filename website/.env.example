# =============================================================================
# iHostMC Website – copy to .env.local (or .env). Never commit .env / .env.local.
# =============================================================================
#
# For tiers/billing to work: point NEXT_PUBLIC_API_URL at the backend that has Stripe configured.
#
# =============================================================================

# Backend API URL (required for sign-in, dashboard, billing, checkout). Browser calls this directly when not using proxy.
# Production: https://api.ihost.one   Local dev: http://localhost:3010
NEXT_PUBLIC_API_URL=https://api.ihost.one
# Server-only fallback when using proxy (no NEXT_PUBLIC_ prefix).
# API_URL=https://api.ihost.one

# When true, browser calls same-origin /api/* and the server proxies to the backend (avoids CORS). When false or unset, browser calls NEXT_PUBLIC_API_URL directly – backend must allow this origin in CORS_ORIGINS.
# NEXT_PUBLIC_USE_API_PROXY=true

# Dev only: skip reCAPTCHA on login/signup (set to true for local testing).
# NEXT_PUBLIC_SKIP_RECAPTCHA=true

# Public URL of this site (required when behind HTTPS proxy so CSS/JS assets load; use HTTPS, no port).
# Main: https://ihost.one   (mc.ihost.one = same marketing; app.ihost.one = app)   Local dev: leave unset
NEXT_PUBLIC_APP_URL=https://ihost.one

# Optional: desktop app download page
# NEXT_PUBLIC_DOWNLOAD_URL=https://github.com/your-org/iHostMC/releases

# Under construction: home shows coming-soon (Formspark form). Set to false when the site is live.
# Server reads SITE_UNDER_CONSTRUCTION at runtime; client uses NEXT_PUBLIC_ at build time. Set both if you use both.
# SITE_UNDER_CONSTRUCTION=true
# NEXT_PUBLIC_SITE_UNDER_CONSTRUCTION=true

# When true: footer and other UI show links to the GitHub repo. Leave unset or false until the repo is public.
# NEXT_PUBLIC_REPO_AVAILABLE=false

# reCAPTCHA v2 site key (public) for coming-soon signup. Use the secret key in Formspark dashboard (Formspark → your form → reCAPTCHA).
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LdATn8sAAAAAFL3kKNJ1hTLVIvqDCSeMepEF2wS
