# =============================================================================
# iHostMC Backend – copy to .env and fill in. Never commit .env.
# =============================================================================
#
# To make all tiers work (Free + Backup $3.99 + Pro $11.99):
#   1. Required: DATABASE_URL, JWT_SECRET (and run: npm run db:migrate)
#   2. For subscriptions: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
#      STRIPE_PRICE_ID_BACKUP, STRIPE_PRICE_ID_PRO (see Stripe section below)
#   3. To test without paying: ALLOW_DEV_TIER_OVERRIDE=true, DEV_TIER_OVERRIDE_SECRET=<secret>
#      Optional: DEV_TIER_OVERRIDE_EMAIL=email@example.com (comma-separated; omit to allow any user)
#
# See docs/SERVER-BILLING-PROMPT.md for server setup steps.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/ihostmc
JWT_SECRET=your-jwt-secret-min-32-chars

# -----------------------------------------------------------------------------
# Tiers (Stripe) – required for Backup / Pro Subscribe and Manage billing
# -----------------------------------------------------------------------------
# 1. Stripe Dashboard (Test mode for testing): create two Products with recurring prices.
STRIPE_SECRET_KEY=sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Backup tier ($3.99/mo): Product "Backup" → Add price 3.99 USD (or EUR) / month recurring → copy price_xxx
STRIPE_PRICE_ID_BACKUP=price_...

# Pro tier ($11.99/mo): Product "Pro" → Add price 11.99 USD (or EUR) / month recurring → copy price_xxx
STRIPE_PRICE_ID_PRO=price_...

# Optional: legacy or catch-all (used by tiers.ts for fallback)
# STRIPE_PRICE_ID_STARTER=
# STRIPE_PRICE_ID=

# 2. Webhook: Developers → Webhooks → Add endpoint
#    URL: https://YOUR_HOST/api/stripe/webhook
#    Events: customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
#    Copy the Signing secret into STRIPE_WEBHOOK_SECRET above.
#
# Test mode: use sk_test_... and test price_xxx; card 4242 4242 4242 4242 (no real charge).

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# Backend port. Website (no NEXT_PUBLIC_API_URL) expects 3010 for local dev.
PORT=3010
# Allowed origins for browser requests (CORS). Required when the website calls the API directly (no proxy). Include the website URL exactly as the browser sends it (e.g. https://ihost.one). Comma-separated; use * for dev only.
CORS_ORIGINS=https://ihost.one,https://www.ihost.one,https://mc.ihost.one,https://app.ihost.one,http://localhost:3000,http://localhost:3847,http://127.0.0.1:3000
WEBSITE_URL=https://ihost.one

# Encrypt API keys at rest (min 32 chars)
ENCRYPTION_KEY=

# Relay (FRP) token for app – returned to logged-in users only
RELAY_PUBLIC_TOKEN=

# CurseForge API key – returned to logged-in users so the app can search/install mods and plugins without each user entering a key (get key from https://console.curseforge.com)
CURSEFORGE_API_KEY=

# xAI (Grok) API key – server-side only for AI features. Get key from console.x.ai. Paste in .env on this server; never commit or expose to clients.
# xAI (Grok): server-side only. Set on server in .env; never exposed to users or the website.
# Used by POST /api/ai/chat to proxy requests; users get AI via our API without seeing this key.
# XAI_API_KEY=xai-...

# User backup uploads directory (must exist or be writable)
BACKUP_STORAGE_PATH=
# Optional: global storage limit in GB (0 = no limit). Overridden by per-tier limits when set.
# BACKUP_STORAGE_LIMIT_GB=0
# Per-tier storage limits in GB: free (e.g. 5 for first users), Backup 15, Pro 100.
# STORAGE_LIMIT_GB_FREE=5
# STORAGE_LIMIT_GB_BACKUP=15
# STORAGE_LIMIT_GB_PRO=100
# Max backups per user: free tier (default 3), Backup/Pro tier (default 30)
# FREE_TIER_MAX_BACKUPS=3
# BACKUP_TIER_MAX_BACKUPS=30

# Email (Resend) – verification and password reset. If unset, verification is skipped.
RESEND_API_KEY=
# With the default "from" (onboarding@resend.dev), Resend only delivers to the email that owns the Resend account. To send to any user (e.g. confirmation emails to friends), verify a domain at https://resend.com/domains and set:
# RESEND_FROM=iHostMC <noreply@yourdomain.com>

# reCAPTCHA v2 secret key – when set, login, signup, forgot-password, and reset-password require a valid reCAPTCHA token (website uses same site key as coming-soon form).
# RECAPTCHA_SECRET_KEY=6LdATn8sAAAAA...
# When true, empty or missing reCAPTCHA token is accepted (dev only; use with SKIP on website to avoid widget).
# RECAPTCHA_ALLOW_EMPTY=true

# -----------------------------------------------------------------------------
# OAuth (Google, GitHub, Discord, Microsoft) – optional; if unset, that provider is hidden
# -----------------------------------------------------------------------------
# Public URL of this backend for OAuth redirect_uri (e.g. https://api.ihost.one). Defaults to WEBSITE_URL or http://localhost:3010.
# BACKEND_PUBLIC_URL=https://api.ihost.one

# Google: Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web app). Authorized redirect URI: {BACKEND_PUBLIC_URL}/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub: Settings → Developer settings → OAuth Apps → New. Authorization callback URL: {BACKEND_PUBLIC_URL}/api/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Discord: Developer Portal → OAuth2 → Redirects: {BACKEND_PUBLIC_URL}/api/auth/discord/callback
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Microsoft: Azure AD app registration → Authentication → Add platform Web. Redirect URI: {BACKEND_PUBLIC_URL}/api/auth/microsoft/callback. API permissions: OpenID, profile, email. Tenant "common" = personal + work.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# -----------------------------------------------------------------------------
# Dev only – test tiers without paying (not for production)
# -----------------------------------------------------------------------------
# Enables Settings → Account "Dev: Switch tier (testing)" and POST /api/dev/set-tier.
# Run npm run db:migrate first. See docs/SERVER-BILLING-PROMPT.md and docs/WINDOWS-BILLING-NEXT-STEPS.md.
# ALLOW_DEV_TIER_OVERRIDE=true
# DEV_TIER_OVERRIDE_SECRET=your-secret
# DEV_TIER_OVERRIDE_EMAIL=overflowedimagination@gmail.com
#   ^ Optional: only these emails can use dev tier override (comma-separated). Omit to allow any signed-in user.
