# Tauri app – copy from .env.public.example or set these. Never commit .env.
# Public values (safe in repo / CI Variables): VITE_API_BASE_URL, VITE_WEBSITE_URL
# See .env.public.example for the canonical public template and GitHub Variables.

# Backend API (Settings → Account, billing, sync & backups, encrypted keys)
# Same machine: http://localhost:3010  |  Remote: https://api.ihost.one
# Sync and backups use this API; website (VITE_WEBSITE_URL) shows "My servers" and backups at e.g. ihost.one/dashboard/backups (no separate storage.ihost.one).
VITE_API_BASE_URL=https://api.ihost.one

# Website URL for sign-in, dashboard, and backups page. If unset, derived from API host + port 3020. Production: https://ihost.one
VITE_WEBSITE_URL=https://ihost.one

# Optional: relay token for dev. Leave unset for release; users get it via sign-in (backend).
# VITE_RELAY_PUBLIC_TOKEN=
