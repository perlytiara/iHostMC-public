{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iHostMC",
  "version": "1.0.7",
  "identifier": "com.ihostmc.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "iHostMC",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "visible": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      },
      "wix": null
    },
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Game",
    "shortDescription": "Minecraft server manager",
    "longDescription": "Cross-platform Minecraft server management with mod/plugin browsing.",
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "ihostmc"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/perlytiara/iHostMC/releases/latest/download/latest.json"
      ]
    }
  }
}
