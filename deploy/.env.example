# iHostMC-builder optional overrides (copy to deploy/.env).
# Builder loads deploy/.env automatically; ecosystem.config.cjs env are defaults.

# GitHub webhook secret (repo Settings → Webhooks → Add secret). If unset, webhook accepts any POST.
# GITHUB_WEBHOOK_SECRET=your_secret

# Private webhook path (unguessable). Default: /_internal/ihostmc-deploy-github-7f3a9b2e4c1d8f6
# Set in GitHub Payload URL as https://api.ihost.one<this_path>. Override only if you use a custom path.
# GITHUB_WEBHOOK_PATH=/_internal/ihostmc-deploy-github-7f3a9b2e4c1d8f6

# Poll deploy branch every N ms (120000 = 2 min). 0 = disable polling.
# POLL_INTERVAL_MS=120000

# PM2 app names to restart after build (comma-separated). Empty = skip PM2.
# PM2_APPS=ihostmc-relay-frps,ihostmc-relay-port-api

# Systemd units to restart after build (comma-separated).
# SYSTEMD_SERVICES=ihostmc-backend,ihostmc-website

# Branch to pull and deploy.
# DEPLOY_BRANCH=main
