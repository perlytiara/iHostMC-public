# Allow the deploy user to restart iHostMC systemd services without a password.
# Install: sudo cp deploy/sudoers-ihostmc-builder /etc/sudoers.d/ihostmc-builder
#          sudo chmod 440 /etc/sudoers.d/ihostmc-builder
# Replace 'ubuntu' with the user that runs the builder (e.g. who runs PM2 for iHostMC-builder).
# Check: sudo -u ubuntu sudo -n systemctl restart ihostmc-backend
ubuntu ALL=(ALL) NOPASSWD: /usr/bin/systemctl daemon-reload
ubuntu ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart ihostmc-backend
ubuntu ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart ihostmc-website
ubuntu ALL=(ALL) NOPASSWD: /usr/sbin/nginx -t
ubuntu ALL=(ALL) NOPASSWD: /usr/bin/systemctl reload nginx
