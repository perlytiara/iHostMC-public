# Public config – safe to commit. Copy to .env for local dev.
# These values are baked into the app build; they are not secret.
#
# GitHub: use Repository Variables (not Secrets) for CI:
#   Settings → Secrets and variables → Actions → Variables
#   Add: VITE_API_BASE_URL, VITE_WEBSITE_URL

# Backend API URL (app and website call this). Production: api.ihost.one
VITE_API_BASE_URL=https://api.ihost.one

# Website URL (login, signup, checkout; app opens this for "Sign in with browser"). Production: ihost.one
VITE_WEBSITE_URL=https://ihost.one

# Optional: default relay (FRP) token. Prefer leaving unset so users get the token
# from the backend after sign-in (GET /api/relay/token). Set only for dev builds.
# VITE_RELAY_PUBLIC_TOKEN=
